# Path to the Google service-account JSON key. Share the target Drive
# folder with this service account's client_email as a viewer.
DRIVE_SERVICE_ACCOUNT_FILE=service-account.json

# ID of the Drive folder to watch (the long id in the folder's URL).
DRIVE_FOLDER_ID=

# Path to the SQLite database file (created automatically if missing).
DB_PATH=taxreader.db

# How often to poll, in seconds (default 300 = 5 minutes).
POLL_INTERVAL_SECONDS=300

# OCR engine for scanned pages: easyocr (default) or pytesseract.
OCR_ENGINE=easyocr
