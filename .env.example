# Anthropic API key used for Claude Haiku PDF extraction.
ANTHROPIC_API_KEY=

# Path to the SQLite database file (created automatically if missing).
DB_PATH=taxreader.db

# Google service-account JSON key path, used to sync the dashboard to a Google Sheet.
GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json

# ID of the target Google Sheet (the long id in its URL) that the dashboard syncs to.
GOOGLE_SHEET_ID=

# Name of the sheet/tab to write to (default: Sheet1).
GOOGLE_SHEET_NAME=Sheet1
